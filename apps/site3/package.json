{
	"name": "site3",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"dev": "vite dev",
		"format": "prettier --write . && eslint . --fix",
		"lint": "prettier --check . && eslint .",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview"
	},
	"devDependencies": {
		"@better-fetch/fetch": "^1.1.21",
		"@eslint/compat": "catalog:lint",
		"@eslint/js": "catalog:lint",
		"@mdit/plugin-container": "catalog:md",
		"@mdit/plugin-snippet": "catalog:md",
		"@repo/ui": "workspace:*",
		"@shikijs/markdown-exit": "catalog:md",
		"@sveltejs/adapter-vercel": "catalog:svelte",
		"@sveltejs/enhanced-img": "^0.9.3",
		"@sveltejs/kit": "catalog:svelte",
		"@sveltejs/vite-plugin-svelte": "catalog:svelte",
		"@tailwindcss/forms": "catalog:tailwind",
		"@tailwindcss/typography": "catalog:tailwind",
		"@tailwindcss/vite": "catalog:tailwind",
		"@types/node": "catalog:types",
		"eslint": "catalog:lint",
		"eslint-config-prettier": "catalog:lint",
		"eslint-plugin-jsonc": "catalog:lint",
		"eslint-plugin-perfectionist": "catalog:lint",
		"eslint-plugin-svelte": "catalog:lint",
		"flexsearch": "catalog:other",
		"globals": "catalog:types",
		"markdown-it-anchor": "catalog:md",
		"mode-watcher": "catalog:util",
		"prettier": "catalog:lint",
		"prettier-plugin-svelte": "catalog:lint",
		"prettier-plugin-tailwindcss": "catalog:lint",
		"svelte": "catalog:svelte",
		"svelte-check": "catalog:svelte",
		"tailwind-merge": "catalog:tailwind",
		"tailwindcss": "catalog:tailwind",
		"typescript": "catalog:types",
		"typescript-eslint": "catalog:lint",
		"vite": "catalog:build",
		"vite-plugin-devtools-json": "catalog:util",
		"vite-plugin-svelte-md": "catalog:md",
		"wellcrafted": "catalog:util"
	}
}
