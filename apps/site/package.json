{
	"name": "site",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "vite build",
		"build:ui": "pnpm --filter @repo/ui build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"dev": "vite dev",
		"format": "prettier --write . && eslint . --fix",
		"lint": "prettier --check . && eslint .",
		"prepare": "pnpm build:ui & svelte-kit sync || echo ''",
		"preview": "vite preview"
	},
	"devDependencies": {
		"@better-fetch/fetch": "catalog:misc",
		"@eslint/js": "catalog:lint",
		"@fontsource/dm-serif-display": "^5.2.8",
		"@fontsource/pretendard": "^5.2.5",
		"@iconify-json/mdi": "catalog:icons",
		"@mdit/plugin-container": "catalog:md",
		"@mdit/plugin-snippet": "catalog:md",
		"@repo/ui": "workspace:*",
		"@resvg/resvg-js": "^2.6.2",
		"@shikijs/markdown-exit": "catalog:md",
		"@sveltejs/adapter-node": "catalog:svelte",
		"@sveltejs/adapter-vercel": "catalog:svelte",
		"@sveltejs/enhanced-img": "catalog:md",
		"@sveltejs/kit": "catalog:svelte",
		"@sveltejs/vite-plugin-svelte": "catalog:svelte",
		"@tailwindcss/forms": "catalog:tailwind",
		"@tailwindcss/typography": "catalog:tailwind",
		"@tailwindcss/vite": "catalog:tailwind",
		"@tanstack/svelte-hotkeys": "catalog:svelte",
		"@types/node": "catalog:types",
		"deepmerge-ts": "^7.1.5",
		"eslint": "catalog:lint",
		"eslint-config-prettier": "catalog:lint",
		"eslint-plugin-jsonc": "catalog:lint",
		"eslint-plugin-perfectionist": "catalog:lint",
		"eslint-plugin-svelte": "catalog:lint",
		"flexsearch": "catalog:misc",
		"globals": "catalog:types",
		"markdown-it-anchor": "catalog:md",
		"mode-watcher": "catalog:svelte",
		"prettier": "catalog:lint",
		"prettier-plugin-svelte": "catalog:lint",
		"prettier-plugin-tailwindcss": "catalog:lint",
		"satori": "^0.26.0",
		"satori-html": "^0.3.2",
		"sv-agentation": "catalog:devtool",
		"svelte": "catalog:svelte",
		"svelte-check": "catalog:svelte",
		"svelte-meta-tags": "^5.0.0",
		"tailwind-merge": "catalog:tailwind",
		"tailwindcss": "catalog:tailwind",
		"typescript": "catalog:types",
		"typescript-eslint": "catalog:lint",
		"unplugin-icons": "catalog:icons",
		"valibot": "catalog:lint",
		"vite": "catalog:ci",
		"vite-plugin-svelte-md": "catalog:md",
		"wellcrafted": "catalog:lint"
	}
}
