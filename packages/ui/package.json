{
	"name": "@repo/ui",
	"version": "0.0.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "catalog:svelte",
		"tailwind-merge": "catalog:tailwind"
	},
	"devDependencies": {
		"@eslint/js": "catalog:lint",
		"@sveltejs/adapter-node": "catalog:svelte",
		"@sveltejs/kit": "catalog:svelte",
		"@sveltejs/package": "catalog:svelte",
		"@sveltejs/vite-plugin-svelte": "catalog:svelte",
		"@types/node": "catalog:types",
		"@vitest/browser-playwright": "catalog:test",
		"eslint": "catalog:lint",
		"eslint-config-prettier": "catalog:lint",
		"eslint-plugin-svelte": "catalog:lint",
		"globals": "catalog:types",
		"lz-string": "catalog:misc",
		"playwright": "catalog:test",
		"prettier": "catalog:lint",
		"prettier-plugin-svelte": "catalog:lint",
		"publint": "catalog:ci",
		"svelte": "catalog:svelte",
		"svelte-check": "catalog:svelte",
		"typescript": "catalog:types",
		"typescript-eslint": "catalog:lint",
		"vite": "catalog:ci",
		"vitest": "catalog:test",
		"vitest-browser-svelte": "catalog:test"
	},
	"keywords": [
		"svelte"
	]
}
